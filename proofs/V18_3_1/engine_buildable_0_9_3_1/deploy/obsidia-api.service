[Unit]
Description=Obsidia API Gateway
After=network.target

[Service]
Type=simple
WorkingDirectory=/opt/obsidia
Environment="OBSIDIA_BIND=local"
Environment="OBSIDIA_STORE_DIR=/opt/obsidia/api_store"
Environment="OBSIDIA_API_KEY="
ExecStart=/usr/bin/env sh -c "python -m uvicorn api_server.main:app --host 127.0.0.1 --port 8000"
Restart=always
RestartSec=2

[Install]
WantedBy=multi-user.target
