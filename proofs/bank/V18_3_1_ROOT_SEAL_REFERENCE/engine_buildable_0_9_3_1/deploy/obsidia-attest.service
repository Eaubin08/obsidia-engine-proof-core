[Unit]
Description=Obsidia attestation generator
After=network.target

[Service]
Type=oneshot
WorkingDirectory=/opt/obsidia
Environment="OBSIDIA_STORE_DIR=/opt/obsidia/api_store"
Environment="OBSIDIA_ATTEST_DIR=/opt/obsidia/api_store/attestations"
Environment="OBSIDIA_KEY_DIR=/opt/obsidia/deploy/keys"
ExecStart=/usr/bin/env sh -c "python api_server/run_attestation.py"
